---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { themeColors } from "../theme.js";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, heroImage, heroImageTitle, tags, readTime } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />
  </head>
  <body class="max-w-2xl mx-auto px-6 py-4 min-h-screen text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header />
    <main>
      <article>
        <div class="flex items-center justify-between mb-6 text-xs text-gray-400 dark:text-gray-500 font-sans tracking-wide">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {readTime && <span>{readTime} read</span>}
        </div>

        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-8 font-heading">{title}</h1>

        {heroImage && (
          <figure class="my-8">
            <img src={heroImage} alt={title} class="w-full rounded-lg" />
            {heroImageTitle && (
              <figcaption class="text-center text-xs text-gray-400 mt-2 italic" set:html={heroImageTitle} />
            )}
          </figure>
        )}

        <div class="prose-content mt-8">
          <slot />
        </div>

        {tags && tags.length > 0 && (
          <div class="flex gap-3 flex-wrap mt-12 pt-6 border-t border-sage-200 dark:border-sage-800">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="text-xs text-sage-600 dark:text-sage-400 hover:underline">#{tag}</a>
            ))}
          </div>
        )}
      </article>
    </main>
    <Footer />
  </body>

  <style is:inline>
    .prose-content {
      line-height: 1.85;
      font-size: 1.0625rem;
    }

    .prose-content h2 {
      font-size: 1.5rem;
      margin-top: 2.5em;
      margin-bottom: 0.75em;
      color: #547257;
    }
    .prose-content h3 {
      font-size: 1.25rem;
      margin-top: 2em;
      margin-bottom: 0.6em;
      color: #547257;
    }
    .prose-content h4 {
      font-size: 1.1rem;
      margin-top: 1.5em;
      margin-bottom: 0.5em;
      color: #6b906d;
    }

    .dark .prose-content h2 { color: #8aab87; }
    .dark .prose-content h3 { color: #8aab87; }
    .dark .prose-content h4 { color: #8aab87; }

    .prose-content p { margin-bottom: 1.35em; }

    .prose-content a {
      color: #547257;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .dark .prose-content a { color: #8aab87; }
    .prose-content a:hover { text-decoration: none; }

    .prose-content ul,
    .prose-content ol {
      margin-bottom: 1.35em;
      padding-left: 1.5em;
    }
    .prose-content ul { list-style: disc; }
    .prose-content ol { list-style: decimal; }
    .prose-content li { margin-bottom: 0.4em; }

    .prose-content blockquote {
      border-left: 3px solid #547257;
      padding: 0.5em 1.25em;
      margin: 1.75em 0;
      color: #6b7280;
      font-style: italic;
    }
    .dark .prose-content blockquote {
      border-left-color: #8aab87;
      color: #9ca3af;
    }

    .prose-content pre {
      padding: 1.25em;
      overflow-x: auto;
      margin: 1.75em 0;
      border-radius: 0.5em;
    }

    .prose-content code:not(pre code) {
      background: #f1f3ec;
      padding: 0.15em 0.4em;
      border-radius: 0.25em;
      font-size: 0.875em;
    }
    .dark .prose-content code:not(pre code) {
      background: #2b3c2e;
    }

    .prose-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.75em 0;
      font-size: 0.9375rem;
    }
    .prose-content th,
    .prose-content td {
      padding: 0.5em 0.75em;
      border: 1px solid #dde3d1;
      text-align: left;
    }
    .dark .prose-content th,
    .dark .prose-content td { border-color: #435c47; }
    .prose-content th {
      background: #f1f3ec;
      font-weight: 600;
    }
    .dark .prose-content th { background: #2b3c2e; }

    .prose-content img {
      max-width: 100%;
      height: auto;
      border-radius: 0.5em;
      margin: 1.5em 0;
    }

    /* Headings never get underlines */
    h1, h2, h3, h4, h5, h6,
    .prose-content h1, .prose-content h2, .prose-content h3,
    .prose-content h4, .prose-content h5, .prose-content h6 {
      text-decoration: none !important;
    }
    h1 a, h2 a, h3 a, h4 a, h5 a, h6 a {
      text-decoration: none !important;
      color: inherit !important;
    }
  </style>
</html>
