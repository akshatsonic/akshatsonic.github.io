---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type Post = CollectionEntry<'blog'>;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const postByYear: { [year: number]: Post[] } = {};
posts.forEach((post) => {
  const year = post.data.pubDate.getFullYear();
  if (!postByYear[year]) postByYear[year] = [];
  postByYear[year].push(post);
});

const years = Object.keys(postByYear).sort((a, b) => parseInt(b) - parseInt(a));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Writing · akshatsonic" description="Essays and notes on backend engineering, databases, and distributed systems." />
  </head>
  <body class="max-w-2xl mx-auto px-6 py-4 min-h-screen text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header />
    <main>
      <h1 class="text-4xl font-bold mb-12 font-heading">Writing</h1>
      {posts.length === 0 ? (
        <p class="text-gray-500">Nothing published yet.</p>
      ) : (
        years.map((year) => (
          <div class="mb-10">
            <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 dark:text-gray-500 mb-4 font-sans">{year}</h2>
            <ul class="flex flex-col divide-y divide-sage-200 dark:divide-sage-800">
              {postByYear[parseInt(year)].map((post: Post) => (
                <li class="py-3.5 flex items-baseline gap-4 md:gap-6">
                  <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums shrink-0 w-12">
                    {post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric' })}
                  </span>
                  <div class="flex flex-col gap-1.5 min-w-0">
                    <a
                      href={`/blog/${post.slug}`}
                      class="text-gray-900 dark:text-gray-100 hover:text-sage-600 dark:hover:text-sage-400 transition-colors leading-snug"
                    >
                      {post.data.title}
                    </a>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex gap-2 flex-wrap">
                        {post.data.tags.map((tag: string) => (
                          <a href={`/tags/${tag}`} class="text-xs text-gray-400 dark:text-gray-500 hover:text-sage-600 dark:hover:text-sage-400 transition-colors">
                            #{tag}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      )}
    </main>
    <Footer />
  </body>
</html>
