---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import RecentPublications from "../components/RecentPublications.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="max-w-2xl mx-auto px-6 py-4 min-h-screen text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header />
    <main>
      <section class="mb-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight font-heading">
          It Works on My Blog!
        </h1>
        <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
          Hey, I'm <strong class="text-gray-900 dark:text-gray-100 font-medium">Akshat Soni</strong>, a backend engineer who spends his days building distributed systems, arguing with databases, and occasionally shipping things that survive production.
        </p>
        <p class="text-base text-gray-500 dark:text-gray-500 leading-relaxed">
          This is where I write about the things I learn, break, and figure out. No fluff, no corporate speak. Just honest notes from someone in the trenches.
        </p>
      </section>
      <RecentPublications />
    </main>
    <Footer />
  </body>
</html>
