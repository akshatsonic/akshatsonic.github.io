---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = await getCollection("blog");
const tagCounts: { [tag: string]: number } = {};

posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Tags · akshatsonic" description="Browse posts by topic." />
  </head>
  <body class="max-w-2xl mx-auto px-6 py-4 min-h-screen text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header />
    <main>
      <h1 class="text-4xl font-bold mb-12 font-heading">Tags</h1>
      <ul class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <li>
            <a
              href={`/tags/${tag}`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm border border-sage-200 dark:border-sage-800 text-gray-600 dark:text-gray-400 hover:border-sage-400 dark:hover:border-sage-600 hover:text-sage-700 dark:hover:text-sage-300 transition-colors"
            >
              #{tag}
              <span class="text-xs text-gray-400 dark:text-gray-600">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
