---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <BaseHead title="404 — Page not found" description="This page doesn't exist." />
  </head>
  <body class="max-w-2xl mx-auto px-6 py-4 min-h-screen text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <Header />
    <main class="flex flex-col items-start gap-4 mt-16">
      <h1 class="text-6xl font-bold font-heading text-sage-300 dark:text-sage-700">404</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">This page doesn't exist.</p>
      <a href="/" class="mt-4 text-sm text-sage-600 dark:text-sage-400 hover:underline">← Back home</a>
    </main>
    <Footer />
  </body>
</html>
