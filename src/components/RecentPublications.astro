---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<section class="mt-16">
  <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 dark:text-gray-500 mb-6 font-sans">Recent Writing</h2>
  <ul class="flex flex-col divide-y divide-sage-200 dark:divide-sage-800">
    {recentPosts.map((post) => (
      <li class="py-3.5 flex items-baseline gap-6">
        <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums shrink-0 w-24">
          {post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}
        </span>
        <a
          href={`/blog/${post.slug}`}
          class="text-gray-900 dark:text-gray-100 hover:text-sage-600 dark:hover:text-sage-400 transition-colors"
        >
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>
  <a
    href="/blog"
    class="inline-block mt-8 text-sm text-sage-600 dark:text-sage-400 hover:underline hover:text-sage-700 dark:hover:text-sage-300"
  >
    All posts →
  </a>
</section>
